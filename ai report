<script>
  let cur=0;
  const slides=document.querySelectorAll('.slide');
  const N=slides.length;
  const dn=document.getElementById('dn');
  const ct=document.getElementById('ct');
  for(let i=0;i<N;i++){const d=document.createElement('div');d.className='dot'+(i===0?' active':'');d.onclick=()=>go(i);dn.appendChild(d);}
  function go(n){slides[cur].classList.remove('active');dn.children[cur].classList.remove('active');cur=(n+N)%N;slides[cur].classList.add('active');dn.children[cur].classList.add('active');ct.textContent=(cur+1)+' / '+N;}
  function next(){go(cur+1);}
  function prev(){go(cur-1);}
  document.addEventListener('keydown',e=>{if(e.key==='ArrowRight'||e.key==='ArrowDown')next();if(e.key==='ArrowLeft'||e.key==='ArrowUp')prev();});
  let sx=0;
  document.addEventListener('touchstart',e=>{sx=e.touches[0].clientX;});
  document.addEventListener('touchend',e=>{const dx=e.changedTouches[0].clientX-sx;if(Math.abs(dx)>50){dx<0?next():prev();}});
</script>
